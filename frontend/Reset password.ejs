<!DOCTYPE html>
<html>
<head>
    <title>Reset Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <h1 class="mt-5">Reset Password</h1>
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-danger">
                <% messages.forEach(function(message) { %>
                    <p><%= message %></p>
                <% }); %>
            </div>
        <% } %>
        <form action="/reset-password" method="POST" class="mt-4">
            <div class="form-group">
                <label for="username">Username:</label>
                <input type="text" id="username" name="username" class="form-control" required 
                <% if (username) { %> value="<%= username %>" <% } %>>
            </div>

              <div class="form-group">
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" class="form-control" required 
                <% if (email) { %> value="<%= email %>" <% } %>>
            </div>

            <% if (question && question.length > 0) { %>
                <div class="form-group mt-3">
                    <label for="securityAnswer"><%= question %></label>
                    <input type="text" id="securityAnswer" name="securityAnswer" class="form-control" required placeholder="Enter your answer">
                </div>
                <div class="form-group mt-3">
                    <label for="newPassword">New Password:</label>
                    <input type="password" id="newPassword" name="newPassword" class="form-control" required placeholder="Enter your new password">
            </div>
            <% } %>
            <button type="submit" class="btn btn-primary mt-4">Reset Password</button>
        </form>
    </div>
</body>
</html>

